# Required to enable live chat at POST /api/chat.
# The zero-key demo at /api/demo needs no key at all.
OPENAI_API_KEY=

# Optional. Local spend ceiling in USD, enforced by floe-guard.
# Defaults to 1.00 when unset.
FLOE_BUDGET_USD=1.00

# Optional. A Floe API key enables a one-time, read-only call to Floe's credit
# API to tighten the local ceiling to your server-side remaining budget.
# This only READS remaining budget; un-bypassable enforcement is hosted Floe.
# Get one at https://dev-dashboard.floelabs.xyz
FLOE_API_KEY=
